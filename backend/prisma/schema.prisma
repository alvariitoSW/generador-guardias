generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RESIDENT
}

enum ScheduleStatus {
  DRAFT
  PUBLISHED
}

enum SwapRequestStatus {
  OPEN
  ACCEPTED
  CANCELLED
}

enum SwapOfferStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model User {
  id             String      @id @default(cuid())
  email          String      @unique
  passwordHash   String
  name           String
  role           Role        @default(RESIDENT)
  // El admin principal es el único que puede nombrar/quitar administradores secundarios.
  isPrimaryAdmin Boolean     @default(false)
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  resident       Resident?
  claimedName    RosterName?
}

// Lista de residentes reales que pueden "reclamar" su nombre al registrarse,
// para que cada cuenta quede atada a una persona conocida y no a un nombre libre.
model RosterName {
  id              String   @id @default(cuid())
  fullName        String   @unique
  claimedByUserId String?  @unique
  claimedBy       User?    @relation(fields: [claimedByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
}

model Resident {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  residencyYear Int? // R1..R5
  // Guardias máximas por mes (por defecto 4, configurable por si cambia la norma)
  monthlyQuota  Int      @default(4)
  createdAt     DateTime @default(now())

  vacations        Vacation[]
  preferences      Preference[]
  assignments      ShiftAssignment[]
  swapRequestsMade SwapRequest[]
  swapOffersMade   SwapOffer[]
}

model Service {
  id             String          @id @default(cuid())
  name           String          @unique // "Urgencias", "UCI", ...
  createdAt      DateTime        @default(now())
  posts          Post[]
  scheduleMonths ScheduleMonth[]
}

model Post {
  id          String            @id @default(cuid())
  serviceId   String
  service     Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  name        String // P1, P2, P3, P4
  slotsPerDay Int               @default(2)
  order       Int               @default(0)
  createdAt   DateTime          @default(now())
  assignments ShiftAssignment[]

  @@unique([serviceId, name])
}

model Vacation {
  id         String   @id @default(cuid())
  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  startDate  DateTime
  endDate    DateTime
  reason     String?
  createdAt  DateTime @default(now())
}

// Preferencias de un residente para un mes concreto de un servicio concreto
model Preference {
  id         String   @id @default(cuid())
  residentId String
  resident   Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)
  serviceId  String
  year       Int
  month      Int // 1-12

  // JSON array de días de la semana a evitar, p.ej. "[1,3,5]" (Lun=1..Vie=5)
  avoidWeekdays            String  @default("[]")
  // JSON array de fechas ISO concretas a evitar dentro del mes (motivos puntuales, no vacaciones)
  avoidDates               String  @default("[]")
  // JSON array de fechas ISO concretas preferidas dentro del mes (máx. 3, se valida en la API)
  preferredDates           String  @default("[]")
  // Si el residente sale de guardia la noche del último día del mes anterior,
  // no se le puede asignar guardia el día 1 de este mes.
  outgoingFirstDay         Boolean @default(false)
  // Guardias del servicio de origen del residente (fuera de Urgencias) este mes:
  // se exige un margen mínimo de OTHER_SERVICE_MIN_GAP_DAYS días (por defecto 4)
  // entre cada una de estas fechas y cualquier guardia de Urgencias.
  hasOtherServiceGuardias  Boolean @default(false)
  otherServiceGuardiaDates String  @default("[]")
  // El objetivo por defecto es el monthlyQuota del residente (normalmente 4). Si este
  // mes va a hacer menos, lo declara aquí (debe ser menor que su objetivo habitual).
  reducedQuota             Int?
  reducedQuotaReason       String?
  preferredPostId          String?
  notes                    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([residentId, serviceId, year, month])
}

model ScheduleMonth {
  id          String         @id @default(cuid())
  serviceId   String
  service     Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  year        Int
  month       Int
  status      ScheduleStatus @default(DRAFT)
  generatedAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime       @default(now())

  assignments ShiftAssignment[]

  @@unique([serviceId, year, month])
}

model ShiftAssignment {
  id              String        @id @default(cuid())
  scheduleMonthId String
  scheduleMonth   ScheduleMonth @relation(fields: [scheduleMonthId], references: [id], onDelete: Cascade)
  postId          String
  post            Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  residentId      String
  resident        Resident      @relation(fields: [residentId], references: [id], onDelete: Cascade)
  date            DateTime
  createdAt       DateTime      @default(now())

  swapRequests    SwapRequest[]
  offeredInOffers SwapOffer[]

  @@unique([postId, date, residentId])
}

// Un residente pide cambiar una de sus guardias ya publicadas. Queda visible
// para todos los demás por si alguien quiere ofrecerse (con o sin una guardia
// suya a cambio). Solo puede haber una solicitud OPEN a la vez por guardia
// (se comprueba en la API, no con una restricción única, para poder volver a
// pedirlo tras cancelar una solicitud anterior).
model SwapRequest {
  id           String            @id @default(cuid())
  assignmentId String
  assignment   ShiftAssignment   @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  requesterId  String
  requester    Resident          @relation(fields: [requesterId], references: [id], onDelete: Cascade)
  note         String?
  status       SwapRequestStatus @default(OPEN)
  createdAt    DateTime          @default(now())
  resolvedAt   DateTime?

  offers SwapOffer[]
}

// Respuesta de otro residente a una solicitud de cambio: puede ofrecer una de
// sus propias guardias a cambio, o simplemente quedarse con la guardia sin
// dar nada (offeredAssignmentId = null).
model SwapOffer {
  id                  String           @id @default(cuid())
  swapRequestId       String
  swapRequest         SwapRequest      @relation(fields: [swapRequestId], references: [id], onDelete: Cascade)
  offererId           String
  offerer             Resident         @relation(fields: [offererId], references: [id], onDelete: Cascade)
  offeredAssignmentId String?
  offeredAssignment   ShiftAssignment? @relation(fields: [offeredAssignmentId], references: [id], onDelete: SetNull)
  note                String?
  status              SwapOfferStatus  @default(PENDING)
  createdAt           DateTime         @default(now())
}
