DATABASE_URL="postgresql://user:password@localhost:5432/guardias"
JWT_SECRET="change-this-to-a-long-random-string"
PORT=4000
# URL del frontend en producción, separadas por comas si hay varias. Vacío = permite cualquier origen (solo para desarrollo).
CORS_ORIGIN=""

# Opcional: aviso por email cuando un residente se registra y elige su nombre de la
# lista. Sin configurar, el registro funciona igual; simplemente no llega email y
# hay que mirar los pendientes en el panel de Residentes. Ejemplo con Gmail
# (necesitas una "contraseña de aplicación", no la contraseña normal de la cuenta):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=tu-cuenta@gmail.com
# SMTP_PASS=contraseña-de-aplicación
# SMTP_FROM=tu-cuenta@gmail.com
# ADMIN_NOTIFY_EMAIL=donde-quieres-el-aviso@gmail.com
